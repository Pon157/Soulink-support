generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  CURATOR
  OWNER
}

enum BanStatus {
  NONE
  WARNED
  BANNED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  nickname      String
  password      String
  avatar        String?
  banner        String?
  theme         String    @default("dark")
  role          Role      @default(USER)
  banStatus     BanStatus @default(NONE)
  warnCount     Int       @default(0)
  isOnRest      Boolean   @default(false)
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relationships
  managedBy     User?     @relation("AdminSupervisor", fields: [managedById], references: [id])
  managedById   String?
  subordinates  User[]    @relation("AdminSupervisor")

  channel       Channel?  @relation("AdminChannel")
  subscriptions Subscription[]
  
  // Chats
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  
  reviews          Review[]  @relation("AdminReviews")
  givenReviews     Review[]  @relation("UserReviews")

  stats            UserStats?
  tasks            Task[]    @relation("AssignedTasks")
  createdTasks     Task[]    @relation("CreatedTasks")
}

model Channel {
  id          String   @id @default(cuid())
  name        String
  avatar      String?
  banner      String?
  description String?
  owner       User     @relation("AdminChannel", fields: [ownerId], references: [id])
  ownerId     String   @unique
  posts       Post[]
  subscribers Subscription[]
}

model Subscription {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  channel   Channel  @relation(fields: [channelId], references: [id])
  channelId String
  createdAt DateTime @default(now())

  @@unique([userId, channelId])
}

model Post {
  id        String   @id @default(cuid())
  content   String
  mediaUrl  String?
  channel   Channel  @relation(fields: [channelId], references: [id])
  channelId String
  createdAt DateTime @default(now())
}

model Message {
  id         String   @id @default(cuid())
  content    String
  mediaUrl   String?
  mediaType  String?  // photo, voice, file
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  senderId   String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  receiverId String
  createdAt  DateTime @default(now())
  read       Boolean  @default(false)
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  mediaUrl  String?
  admin     User     @relation("AdminReviews", fields: [adminId], references: [id])
  adminId   String
  user      User     @relation("UserReviews", fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String
  status      String   @default("pending") // pending, completed
  assignee    User     @relation("AssignedTasks", fields: [assigneeId], references: [id])
  assigneeId  String
  creator     User     @relation("CreatedTasks", fields: [creatorId], references: [id])
  creatorId   String
  deadline    DateTime?
  createdAt   DateTime @default(now())
}

model UserStats {
  id              String @id @default(cuid())
  user            User   @relation(fields: [userId], references: [id])
  userId          String @unique
  dialogsCount    Int    @default(0)
  messagesSent    Int    @default(0)
  averageRating   Float  @default(0)
  completionRate  Float  @default(0)
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String   @unique
  code      String
  expiresAt DateTime
}
